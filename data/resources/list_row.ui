<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <template class="MellowListRow" parent="AdwActionRow">

    <!-- FIX: List row should have a fixed height -->

    <property name="title_lines">1</property>
    <property name="subtitle_lines">1</property>
    <property name="use_markup">False</property>
    <property name="activatable">True</property>

    <child type="prefix">
      <object class="GtkPicture" id="prefix_image">
        <property name="valign">center</property>
        <property name="content_fit">contain</property>
        <property name="margin_top">7</property>
        <property name="margin_bottom">7</property>
        <style>
          <class name="card"/>
        </style>
      </object>
    </child>

    <child type="suffix">
      <object class="GtkLabel" id="suffix_label">
        <style>
          <class name="dimmed"/>
          <class name="numeric"/>
        </style>
      </object>
    </child>

    <child type="suffix">
      <object class="GtkImage" id="open_subpage_icon">
        <property name="margin_start">9</property>
        <property name="margin_end">1</property>
        <property name="icon_name">go-next-symbolic</property>
      </object>
    </child>
    <child type="suffix">
      <object class="GtkCheckButton" id="selection_toggle">
        <property name="width_request">8</property>
        <property name="visible">False</property>
      </object>
    </child>

  </template>
</interface>

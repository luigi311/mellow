<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="libadwaita" version="1.8"/>
  <template class="MellowWindow" parent="AdwApplicationWindow">
    <property name="title">Mellow</property>
    <property name="width_request">0</property>
    <property name="height_request">0</property>

    <!-- TODO: Organize views into separate files/widgets -->

    <child>
      <object class="AdwBottomSheet" id="sheet">
        <style>
          <class name="view"/>
        </style>
        <property name="content">
          <object class="AdwToolbarView">

            <child type="top">
              <object class="AdwHeaderBar">
                <property name="show-title">False</property>
              </object>
            </child>
            <child type="top">
              <object class="GtkProgressBar" id="progress_bar">
                <property name="visible">False</property>
                <style>
                  <class name="osd"/>
                </style>
              </object>
            </child>

            <!-- Main player view -->
            <property name="content">
              <object class="GtkWindowHandle">
                <child>
                  <object class="GtkBox">
                    <property name="spacing">6</property>
                    <property name="margin_top">0</property>
                    <property name="margin_bottom">6</property>
                    <property name="margin_start">26</property>
                    <property name="margin_end">26</property>
                    <property name="vexpand">True</property>
                    <property name="hexpand">True</property>
                    <property name="valign">center</property>
                    <property name="orientation">vertical</property>

                    <!-- Song info -->
                    <child>
                      <object class="GtkPicture" id="album_cover">
                        <property name="content_fit">contain</property>
                        <property name="halign">center</property>
                        <property name="width_request">0</property>
                        <property name="height_request">0</property>
                        <style>
                          <class name="card"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="song_title">
                        <property name="margin_top">6</property>
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="album_title">
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="caption-heading"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="artist_name">
                        <property name="margin_bottom">6</property>
                        <property name="ellipsize">end</property>
                        <style>
                          <class name="caption-heading"/>
                        </style>
                      </object>
                    </child>

                    <!-- Media controls -->
                    <child type="overlay">
                      <object class="GtkBox" id="media_controls">
                        <property name="orientation">vertical</property>
                        <property name="hexpand">True</property>
                        <property name="sensitive">False</property>
                        <style>
                          <class name="toolbar"/>
                          <class name="osd"/>
                        </style>
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="halign">center</property>
                            <property name="hexpand">True</property>
                            <property name="spacing">12</property>
                            <property name="margin_start">6</property>
                            <property name="margin_end">6</property>

                            <!-- Media buttons -->
                            <child>
                              <object class="GtkButton" id="prev_button">
                                <signal name="clicked" handler="handle_skip_prev" swapped="true"/>
                                <property name="icon_name">media-skip-backward-symbolic</property>
                                <style>
                                  <class name="circular"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="pause_button">
                                <signal name="clicked" handler="handle_play_pause" swapped="true"/>
                                <property name="icon_name">media-playback-start-symbolic</property>
                                <style>
                                  <class name="circular"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkButton" id="next_button">
                                <signal name="clicked" handler="handle_skip_next" swapped="true"/>
                                <property name="icon_name">media-skip-forward-symbolic</property>
                                <style>
                                  <class name="circular"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Seek bar -->
                        <child>
                          <object class="GtkBox">
                            <property name="hexpand">True</property>
                            <child>
                              <object class="GtkLabel" id="time_cur_label">
                                <property name="label">-:--</property>
                                <property name="halign">start</property>
                                <style>
                                  <class name="numeric"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkScale" id="seek_bar">
                                <signal name="change_value" handler="handle_seek" swapped="true"/>
                                <property name="hexpand">True</property>
                                <property name="margin_start">6</property>
                                <property name="margin_end">6</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">1</property>
                                    <property name="value">0</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="time_end_label">
                                <property name="label">-:--</property>
                                <property name="halign">end</property>
                                <style>
                                  <class name="numeric"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>

                    <!-- Padding to account for the bottom bar -->
                    <child>
                      <object class="GtkBox">
                        <property name="height_request">24</property>
                        <property name="hexpand">True</property>
                      </object>
                    </child>

                  </object>
                </child>
              </object>
            </property>

          </object>
        </property>

        <property name="bottom-bar">
          <object class="GtkCenterBox">
            <style>
              <class name="view"/>
              <class name="flat"/>
            </style>
            <property name="height-request">30</property>
            <property name="center-widget">
              <object class="GtkImage">
                <property name="icon_name">view-continuous-symbolic</property>
                <style>
                  <class name="dimmed"/>
                </style>
              </object>
            </property>
          </object>
        </property>

        <!-- Bottom sheet overlay -->

        <property name="show-drag-handle">False</property>
        <property name="sheet">

          <object class="AdwToolbarView">
            <style>
              <class name="osd"/>
            </style>

            <property name="content">
              <object class="AdwViewStack" id="view_stack">

                <!-- Library -->
                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">library</property>
                    <property name="title" translatable="yes">_Library</property>
                    <property name="icon-name">applications-multimedia-symbolic</property>
                    <property name="use-underline">True</property>
                    <property name="child">

                      <object class="AdwNavigationView">
                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Library</property>
                            <property name="tag">library</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwPreferencesPage">
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="AdwPreferencesGroup">
                                        <child>
                                          <object class="AdwActionRow">
                                            <property name="title">Songs</property>
                                            <property name="activatable">True</property>
                                            <property name="action-name">navigation.push</property>
                                            <property name="action-target">'library_songs'</property>
                                            <child type="prefix">
                                              <object class="GtkImage">
                                                <property name="icon_name">audio-x-generic-symbolic</property>
                                              </object>
                                            </child>
                                            <child type="suffix">
                                              <object class="GtkImage">
                                                <property name="icon_name">go-next-symbolic</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwActionRow">
                                            <property name="title">Albums</property>
                                            <property name="activatable">True</property>
                                            <property name="action-name">navigation.push</property>
                                            <property name="action-target">'library_albums'</property>
                                            <child type="prefix">
                                              <object class="GtkImage">
                                                <property name="icon_name">media-optical-cd-audio-symbolic</property>
                                              </object>
                                            </child>
                                            <child type="suffix">
                                              <object class="GtkImage">
                                                <property name="icon_name">go-next-symbolic</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwActionRow">
                                            <property name="title">Artists</property>
                                            <property name="activatable">True</property>
                                            <property name="action-name">navigation.push</property>
                                            <property name="action-target">'library_artists'</property>
                                            <child type="prefix">
                                              <object class="GtkImage">
                                                <property name="icon_name">avatar-default-symbolic</property>
                                              </object>
                                            </child>
                                            <child type="suffix">
                                              <object class="GtkImage">
                                                <property name="icon_name">go-next-symbolic</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>


                            </property>
                          </object>
                        </child>

                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Songs</property>
                            <property name="tag">library_songs</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwStatusPage">
                                    <property name="icon-name">audio-x-generic-symbolic</property>
                                    <property name="title" translatable="yes">Songs</property>
                                    <property name="description" translatable="yes">Songs will appear here in a future version</property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Albums</property>
                            <property name="tag">library_albums</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwStatusPage">
                                    <property name="icon-name">media-optical-cd-audio-symbolic</property>
                                    <property name="title" translatable="yes">Albums</property>
                                    <property name="description" translatable="yes">Albums will appear here in a future version</property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Artists</property>
                            <property name="tag">library_artists</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwStatusPage">
                                    <property name="icon-name">avatar-default-symbolic</property>
                                    <property name="title" translatable="yes">Artists</property>
                                    <property name="description" translatable="yes">Artists will appear here in a future version</property>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>

                      </object>
                    </property>
                  </object>
                </child>

                <!-- Playing -->
                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">playing</property>
                    <property name="title" translatable="yes">_Playing</property>
                    <property name="icon-name">media-playback-start-symbolic</property>
                    <property name="use-underline">True</property>
                    <property name="child">
                      <object class="AdwNavigationView">

                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Playing</property>
                            <property name="tag">playing</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwPreferencesPage">
                                    <property name="valign">center</property>
                                    <child>
                                      <object class="AdwPreferencesGroup">

                                        <!-- TODO: Show song info -->
                                        <child>
                                          <object class="AdwPreferencesRow">
                                            <child>
                                              <object class="GtkBox">
                                                <property name="orientation">vertical</property>
                                                <property name="halign">center</property>
                                                <child>
                                                  <object class="GtkLabel" id="playing_song_title">
                                                    <property name="margin_top">6</property>
                                                    <property name="justify">center</property>
                                                    <property name="wrap">true</property>
                                                    <property name="wrap-mode">word</property>
                                                    <style>
                                                      <class name="heading"/>
                                                    </style>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel" id="playing_album_title">
                                                    <property name="margin_top">6</property>
                                                    <property name="justify">center</property>
                                                    <property name="wrap">true</property>
                                                    <property name="wrap-mode">word</property>
                                                    <style>
                                                      <class name="caption-heading"/>
                                                    </style>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkLabel" id="playing_artist_name">
                                                    <property name="margin_top">6</property>
                                                    <property name="margin_bottom">6</property>
                                                    <property name="justify">center</property>
                                                    <property name="wrap">true</property>
                                                    <property name="wrap-mode">word</property>
                                                    <style>
                                                      <class name="caption-heading"/>
                                                    </style>
                                                  </object>
                                                </child>
                                                <child>
                                                  <object class="GtkBox">
                                                    <property name="halign">center</property>
                                                    <child>
                                                      <object class="GtkButton">
                                                        <property name="icon_name">starred-symbolic</property>
                                                        <style>
                                                          <class name="flat"/>
                                                          <class name="circular"/>
                                                        </style>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkButton">
                                                        <property name="icon_name">starred-symbolic</property>
                                                        <style>
                                                          <class name="flat"/>
                                                          <class name="circular"/>
                                                        </style>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkButton">
                                                        <property name="icon_name">starred-symbolic</property>
                                                        <style>
                                                          <class name="flat"/>
                                                          <class name="circular"/>
                                                        </style>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkButton">
                                                        <property name="icon_name">starred-symbolic</property>
                                                        <style>
                                                          <class name="flat"/>
                                                          <class name="circular"/>
                                                        </style>
                                                      </object>
                                                    </child>
                                                    <child>
                                                      <object class="GtkButton">
                                                        <property name="icon_name">starred-symbolic</property>
                                                        <style>
                                                          <class name="flat"/>
                                                          <class name="circular"/>
                                                        </style>
                                                      </object>
                                                    </child>
                                                  </object>
                                                </child>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="AdwActionRow">
                                            <property name="title">Lyrics</property>
                                            <property name="activatable">True</property>
                                            <property name="action-name">navigation.push</property>
                                            <property name="action-target">'lyrics'</property>
                                            <child type="prefix">
                                              <object class="GtkImage">
                                                <property name="icon_name">text-x-generic-symbolic</property>
                                              </object>
                                            </child>
                                            <child type="suffix">
                                              <object class="GtkImage">
                                                <property name="icon_name">go-next-symbolic</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="AdwPreferencesGroup">
                                        <child>
                                          <object class="AdwActionRow">
                                            <property name="title">Song Queue</property>
                                            <property name="activatable">True</property>
                                            <property name="action-name">navigation.push</property>
                                            <property name="action-target">'song_queue'</property>
                                            <child type="prefix">
                                              <object class="GtkImage">
                                                <property name="icon_name">media-playlist-consecutive-symbolic</property>
                                              </object>
                                            </child>
                                            <child type="suffix">
                                              <object class="GtkImage">
                                                <property name="icon_name">go-next-symbolic</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>

                                      </object>
                                    </child>
                                  </object>

                                </property>
                              </object>
                            </property>
                          </object>
                        </child>

                        <!-- Lyrics -->
                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Lyrics</property>
                            <property name="tag">lyrics</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                    <!-- <property name="title_widget"> -->
                                      <!-- <object class="AdwWindowTitle" id="lyrics_page_title"> -->
                                        <!-- <property name="title"></property> -->
                                      <!-- </object> -->
                                    <!-- </property> -->
                                  </object>
                                </child>
                                <property name="content">
                                  <object class="AdwStatusPage">
                                    <style>
                                      <class name="compact"/>
                                    </style>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="halign">center</property>
                                        <property name="spacing">16</property>
                                        <child>
                                          <object class="GtkLabel" id="info_song_title">
                                            <property name="justify">center</property>
                                            <property name="wrap_mode">word</property>
                                            <property name="wrap">True</property>
                                            <property name="hexpand">True</property>
                                            <property name="halign">center</property>
                                            <property name="margin_start">12</property>
                                            <property name="margin_end">12</property>
                                            <property name="wrap_mode">word</property>
                                            <style>
                                              <class name="heading"/>
                                            </style>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkLabel" id="info_lyrics">
                                            <property name="label" translatable="yes">Lyrics not available</property>
                                            <property name="justify">center</property>
                                            <property name="wrap_mode">word</property>
                                            <property name="wrap">True</property>
                                            <property name="hexpand">True</property>
                                            <property name="halign">center</property>
                                            <property name="margin_start">12</property>
                                            <property name="margin_end">12</property>
                                            <property name="wrap_mode">word</property>
                                            <style>
                                              <class name="body"/>
                                            </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>

                        <!-- Song queue -->
                        <child>
                          <object class="AdwNavigationPage">
                            <property name="title" translatable="yes">Song Queue</property>
                            <property name="tag">song_queue</property>
                            <property name="child">
                              <object class="AdwToolbarView">
                                <child type="top">
                                  <object class="AdwHeaderBar">
                                    <property name="show_title">False</property>
                                    <child type="end">
                                      <object class="GtkToggleButton" id="shuffle_toggle">
                                        <signal name="toggled" handler="handle_set_shuffle" swapped="true"/>
                                        <property name="icon_name">media-playlist-shuffle-symbolic</property>
                                        <property name="tooltip-text" translatable="yes">Shuffle</property>
                                      </object>
                                    </child>
                                    <child type="end">
                                      <object class="GtkToggleButton" id="repeat_toggle">
                                        <signal name="toggled" handler="handle_set_repeat" swapped="true"/>
                                        <property name="icon_name">media-playlist-repeat-symbolic</property>
                                        <property name="tooltip-text" translatable="yes">Repeat</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                                <!-- IDEA: Queue items could be AdwExpanderRows, expanding into -->
                                <!-- "Play now", a ratings widget, "Stop after", etc -->
                                <!-- Alternatively, a context menu might be useful for this -->
                                <property name="content">
                                  <object class="AdwPreferencesPage">
                                    <property name="valign">center</property>

                                    <!-- List of songs in the queue -->
                                    <child>
                                      <!-- TODO: Button to scroll back to the playing song -->
                                      <object class="AdwPreferencesGroup" id="song_queue_group">
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </property>
                          </object>
                        </child>

                      </object>
                    </property>
                  </object>
                </child>

                <!-- Settings -->
                <child>
                  <object class="AdwViewStackPage">
                    <property name="name">settings</property>
                    <property name="title" translatable="yes">_Settings</property>
                    <property name="icon-name">preferences-system-symbolic</property>
                    <property name="use-underline">True</property>
                    <property name="child">
                      <object class="AdwToolbarView">
                        <child type="top">
                          <object class="AdwHeaderBar">
                            <property name="show_title">False</property>
                          </object>
                        </child>
                        <property name="content">
                          <object class="AdwPreferencesPage">
                            <property name="valign">center</property>

                            <!-- Playback settings -->
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="hexpand">True</property>
                                <property name="title" translatable="yes">Playback</property>

                                <child>
                                  <object class="AdwPreferencesRow">
                                    <child>
                                      <object class="GtkBox">
                                        <style>
                                          <class name="horizontal"/>
                                        </style>
                                        <property name="margin_top">12</property>
                                        <property name="margin_bottom">12</property>
                                        <property name="margin_start">12</property>
                                        <property name="margin_end">12</property>
                                        <child>
                                          <object class="GtkLabel">
                                            <property name="label" translatable="yes">Volume</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkScale">
                                            <signal name="change_value" handler="handle_set_volume" swapped="true"/>
                                            <property name="hexpand">True</property>
                                            <property name="adjustment">
                                              <object class="GtkAdjustment">
                                                <property name="lower">0</property>
                                                <property name="upper">1</property>
                                                <property name="value">1</property>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </child>

                                <child>
                                  <object class="AdwSwitchRow" id="settings_gapless">
                                    <signal name="notify::active" handler="handle_gapless_switch" swapped="true"/>
                                    <property name="title" translatable="yes">Gapless</property>
                                    <property name="active">True</property>
                                  </object>
                                </child>
                              </object>
                            </child>

                            <!-- Library settings -->
                            <child>
                              <object class="AdwPreferencesGroup">
                                <property name="hexpand">True</property>
                                <property name="title" translatable="yes">Library</property>
                                <child>
                                  <object class="AdwExpanderRow" id="settings_directories">
                                    <property name="title" translatable="yes">Directories</property>
                                    <property name="expanded">True</property>
                                    <child>
                                      <!-- TODO: Allow adding/removing directories -->
                                      <object class="AdwButtonRow">
                                        <signal name="activated" handler="handle_add_library" swapped="true"/>
                                        <property name="title" translatable="yes">Add Directory</property>
                                        <property name="start_icon_name">list-add-symbolic</property>
                                        <!-- <style> -->
                                          <!-- <class name="suggested-action"/> -->
                                        <!-- </style> -->
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </property>
                  </object>
                </child>

              </object>
            </property>

            <!-- TODO: Show a banner with song info, close bottom sheet on click -->
            <!-- <child type="bottom"> -->
              <!-- <object class="GtkBox"> -->
                <!-- <property name="height_request">46</property> -->
                <!-- <style> -->
                  <!-- <class name="osd"/> -->
                <!-- </style> -->
              <!-- </object> -->
            <!-- </child> -->

            <child type="bottom">
              <object class="AdwViewSwitcherBar">
                <property name="stack">view_stack</property>
                <property name="reveal">True</property>
              </object>
            </child>
          </object>
        </property>

      </object>
    </child>

  </template>
</interface>

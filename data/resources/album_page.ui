<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="play_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Sequential</attribute>
        <attribute name='action'>menu.album_page_play_mode</attribute>
        <attribute name='target' type='s'>"Sequential"</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Shuffled</attribute>
        <attribute name='action'>menu.album_page_play_mode</attribute>
        <attribute name='target' type='s'>"Shuffled"</attribute>
      </item>
    </section>
  </menu>
  <template class="MellowAlbumPage" parent="AdwNavigationPage">

    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="show_title">False</property>
            <child type="end">
              <object class="AdwSplitButton" id="play_button">
                <signal name="clicked" handler="handle_play_now" swapped="true"/>
                <property name="menu-model">play_menu</property>
                <property name="icon-name">media-playback-start-symbolic</property>
                <property name="tooltip-text" translatable="yes">Play All</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <property name="valign">center</property>
            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="AdwPreferencesRow">
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>

                        Album artwork
                        <child>
                          <object class="GtkPicture" id="album_cover">
                            <property name="margin_start">16</property>
                            <property name="margin_end">16</property>
                            <property name="margin_top">16</property>
                            <property name="content_fit">contain</property>
                            <property name="halign">center</property>
                            <property name="width_request">256</property>
                            <property name="height_request">256</property>
                            <style>
                              <class name="card"/>
                            </style>
                          </object>
                        </child>

                        Album info
                        <child>
                          <object class="GtkBox">
                            <property name="margin_top">16</property>
                            <property name="margin_bottom">14</property>
                            <property name="spacing">6</property>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel" id="artist_name">
                                <property name="wrap">true</property>
                                <property name="wrap-mode">word</property>
                                <property name="justify">center</property>
                                <style>
                                  <class name="caption-heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="album_title">
                                <property name="wrap">true</property>
                                <property name="wrap-mode">word</property>
                                <property name="justify">center</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="year">
                                <property name="margin_bottom">8</property>
                                <style>
                                  <class name="caption-heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="MellowRating" id="rating"/>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="GtkListBox" id="songs_list">
                    <property name="selection_mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="AdwActionRow">
                    <signal name="activated" handler="handle_go_to_artist" swapped="true"/>
                    <property name="title" translatable="yes">Go To Artist</property>
                    <property name="activatable">True</property>
                    <child type="prefix">
                      <object class="GtkImage">
                        <property name="icon_name">avatar-default-symbolic</property>
                      </object>
                    </child>
                    <child type="suffix">
                      <object class="GtkImage">
                        <property name="icon_name">go-next-symbolic</property>
                      </object>
                    </child>
                  </object>
                </child>

              </object>
            </child>

          </object>
        </property>
      </object>
    </property>

  </template>
</interface>

<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <menu id="play_menu">
    <section>
      <item>
        <attribute name="label" translatable="yes">Play</attribute>
        <attribute name='action'>player.play_visible_album</attribute>
      </item>
      <item>
        <attribute name="label" translatable="yes">Shuffle</attribute>
        <attribute name='action'>player.shuffle_visible_album</attribute>
      </item>
    </section>
  </menu>
  <template class="MellowAlbumPage" parent="AdwNavigationPage">

    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="show_title">False</property>

            <!-- TODO: Change how these buttons work -->
            <!-- Ideally, they would work like a regular dropdown to select the -->
            <!-- behavior of the play button, rather than start a queue directly -->

            <child type="end">
              <object class="AdwSplitButton" id="play_button">
                <signal name="clicked" handler="handle_play_sequential" swapped="true"/>
                <property name="menu-model">play_menu</property>
                <property name="icon-name">media-playback-start-symbolic</property>
                <property name="tooltip-text" translatable="yes">Play All</property>
              </object>
            </child>
            <child type="end">
              <object class="AdwSplitButton" id="shuffle_button">
                <property name="visible">false</property>
                <signal name="clicked" handler="handle_play_shuffled" swapped="true"/>
                <property name="menu-model">play_menu</property>
                <property name="icon-name">media-playlist-shuffle-symbolic</property>
                <property name="tooltip-text" translatable="yes">Play Shuffled</property>
              </object>
            </child>
          </object>
        </child>
        <property name="content">
          <object class="AdwPreferencesPage">
            <property name="valign">center</property>
            <child>
              <object class="AdwPreferencesGroup">

                <child>
                  <object class="AdwButtonRow">
                    <!-- FIX: It is unintuitive to make this a 'Go To Artist' button -->
                    <!-- FIX: Making this a button interferes with the rating widget -->
                    <signal name="activated" handler="handle_go_to_artist" swapped="true"/>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="halign">center</property>

                        Album artwork
                        <child>
                          <object class="GtkPicture" id="album_cover">
                            <property name="margin_start">16</property>
                            <property name="margin_end">16</property>
                            <property name="margin_top">16</property>
                            <property name="content_fit">contain</property>
                            <property name="halign">center</property>
                            <property name="width_request">256</property>
                            <property name="height_request">256</property>
                            <style>
                              <class name="card"/>
                            </style>
                          </object>
                        </child>

                        Album info
                        <child>
                          <object class="GtkBox">
                            <property name="margin_top">16</property>
                            <property name="margin_bottom">14</property>
                            <property name="spacing">6</property>
                            <property name="orientation">vertical</property>
                            <child>
                              <object class="GtkLabel" id="artist_name">
                                <property name="wrap">true</property>
                                <property name="wrap-mode">word</property>
                                <property name="justify">center</property>
                                <style>
                                  <class name="caption-heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="album_title">
                                <property name="wrap">true</property>
                                <property name="wrap-mode">word</property>
                                <property name="justify">center</property>
                                <style>
                                  <class name="heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="GtkLabel" id="year">
                                <property name="margin_bottom">8</property>
                                <style>
                                  <class name="caption-heading"/>
                                </style>
                              </object>
                            </child>
                            <child>
                              <object class="MellowRating" id="rating">
                                <property name="sensitive">False</property>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>

            <child>
              <object class="AdwPreferencesGroup">
                <child>
                  <object class="GtkListBox" id="songs_list">
                    <property name="selection_mode">none</property>
                    <style>
                      <class name="boxed-list"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>

          </object>
        </property>
      </object>
    </property>

  </template>
</interface>

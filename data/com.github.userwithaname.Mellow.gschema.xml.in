<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="com.github.userwithaname.Mellow.color-scheme">
    <value nick="Dark" value="0"/>
    <value nick="Light" value="1"/>
    <value nick="Auto" value="2"/>
  </enum>

  <schema id="com.github.userwithaname.Mellow" path="/com/github/userwithaname/Mellow/">
    <key name="window-width" type="i">
      <default>540</default>
      <summary>Width of the window (in pixels)</summary>
    </key>
    <key name="window-height" type="i">
      <default>720</default>
      <summary>Height of the window (in pixels)</summary>
    </key>
    <key name="volume" type="d">
      <default>1</default>
      <summary>Playback volume (0 to 1)</summary>
    </key>
    <key name="gapless" type="b">
      <default>true</default>
      <summary>When enabled, the next song starts loading before the current one ends, to ensure uninterrupted playback</summary>
    </key>
    <key name="remember-queue" type="b">
      <default>true</default>
      <summary>When enabled, the song queue is preserved between sessions</summary>
    </key>
    <key name="adaptive-colors" type="b">
      <default>true</default>
      <summary>When enabled, the window colors adapt to the song artwork</summary>
    </key>
    <key name="color-scheme" enum="com.github.userwithaname.Mellow.color-scheme">
      <default>'Dark'</default>
    </key>
    <key name="directories" type="s">
      <default>":"</default>
      <summary>Directories within which the player will look for music files</summary>
    </key>
  </schema>
</schemalist>

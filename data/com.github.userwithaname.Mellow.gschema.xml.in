<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="com.github.userwithaname.Mellow.color-scheme">
    <value nick="Dark" value="0"/>
    <value nick="Light" value="1"/>
    <value nick="Auto" value="2"/>
  </enum>
  <enum id="com.github.userwithaname.Mellow.startup-queue">
    <value nick="RestoreQueue" value="0"/>
    <value nick="QueueFromSongs" value="1"/>
    <value nick="QueueFromAlbums" value="2"/>
    <value nick="QueueFromArtists" value="3"/>
    <value nick="QueueFromSongsShuffled" value="4"/>
    <value nick="QueueFromAlbumsShuffled" value="5"/>
    <value nick="QueueFromArtistsShuffled" value="6"/>
    <value nick="EmptyQueue" value="7"/>
  </enum>

  <schema id="com.github.userwithaname.Mellow" path="/com/github/userwithaname/Mellow/">
    <key name="window-width" type="i">
      <default>540</default>
      <summary>Width of the window (in pixels)</summary>
    </key>
    <key name="window-height" type="i">
      <default>720</default>
      <summary>Height of the window (in pixels)</summary>
    </key>
    <key name="volume" type="d">
      <default>1</default>
      <summary>Playback volume (0 to 1)</summary>
    </key>
    <key name="gapless" type="b">
      <default>true</default>
      <summary>When enabled, the next song starts loading before the current one ends, to ensure uninterrupted playback</summary>
    </key>
    <key name="startup-queue" enum="com.github.userwithaname.Mellow.startup-queue">
      <default>'RestoreQueue'</default>
    </key>
    <key name="remember-time" type="b">
      <default>true</default>
      <summary>When enabled, the playback time is preserved between sessions</summary>
    </key>
    <key name="adaptive-colors" type="b">
      <default>true</default>
      <summary>When enabled, the window colors adapt to the song artwork</summary>
    </key>
    <key name="color-scheme" enum="com.github.userwithaname.Mellow.color-scheme">
      <default>'Auto'</default>
    </key>
    <key name="directories" type="s">
      <default>":"</default>
      <summary>Directories within which the player will look for music files</summary>
    </key>
    <key name="songs-shuffle" type="b">
      <default>false</default>
      <summary>Whether the play button on the songs page should start a shuffled queue</summary>
    </key>
    <key name="albums-shuffle" type="b">
      <default>false</default>
      <summary>Whether the play button on the albums page should start a shuffled queue</summary>
    </key>
    <key name="artists-shuffle" type="b">
      <default>false</default>
      <summary>Whether the play button on the artists page should start a shuffled queue</summary>
    </key>
  </schema>
</schemalist>
